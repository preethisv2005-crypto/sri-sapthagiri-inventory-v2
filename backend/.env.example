# MongoDB Connection String (required)
# Replace with your MongoDB Atlas URI
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sapthagiri_inventory?retryWrites=true&w=majority

# Server Port (Render assigns this automatically, keep default)
PORT=3001

# Environment
NODE_ENV=production

# Admin Password (used for frontend login)
ADMIN_PASSWORD=your_secure_admin_password_here

# Transporter Password (used for transporter login)
TRANSPORTER_PASSWORD=your_secure_transporter_password_here
