# --- Sri Sapthagiri Logistics - Backend Configuration ---

# Server Port (Default: 3001)
PORT=3001

# MongoDB Connection URI (REQUIRED)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
# IMPORTANT: Special characters in passwords MUST be URL-encoded.
# '@' → %40  |  '#' → %23  |  '%' → %25
MONGO_URI=mongodb+srv://hariprasada2910_db_user:AePJVvOE8p2pMU64@cluster0.b0gwoqj.mongodb.net/?appName=Cluster0

# Node Environment (development or production)
NODE_ENV=development

# Admin Password (used for frontend login — must match the hardcoded value in frontend/js/app.js)
ADMIN_PASSWORD=12345678

# Transporter Password (must match frontend/js/app.js)
TRANSPORTER_PASSWORD=transporter123

# --- Note on Connection Issues ---
# 1. Ensure your MongoDB cluster allows your current IP address (Network Access in Atlas).
# 2. Check if your MONGO_URI contains special characters; if so, they must be URL encoded.
# 3. If running locally, ensure the MongoDB service is started.
