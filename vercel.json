{
  "version": 2,
  "functions": {
    "api/server.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/server.js"
    },
    {
      "source": "/((?!api|css|js|assets|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
